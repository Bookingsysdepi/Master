<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CineBook</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/responsive.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CineBook.styles.css" asp-append-version="true" />
</head>
<body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark cine-navbar" aria-label="Primary navigation">
            <div class="container">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-ticket-perforated-fill" aria-hidden="true"></i></span>
                    <span>CineBook</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#primaryNavigation" aria-controls="primaryNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="primaryNavigation">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door" aria-hidden="true"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Movies" asp-action="Index"><i class="bi bi-camera-reels" aria-hidden="true"></i> Movies</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Bookings" asp-action="MyBookings"><i class="bi bi-bag-check" aria-hidden="true"></i> My Bookings</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-grid-1x2" aria-hidden="true"></i> Admin
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="adminMenu">
                                        <li><a class="dropdown-item" href="/Admin/Movies">Movies</a></li>
                                        <li><a class="dropdown-item" href="/Admin/Employees">Employees</a></li>
                                        <li><a class="dropdown-item" href="/Admin/Snacks">Canteen</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole("CanteenEmployee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" href="/Canteen"><i class="bi bi-cup-straw" aria-hidden="true"></i> Canteen</a>
                                </li>
                            }
                            <li class="nav-item nav-user">
                                <span class="nav-link"><i class="bi bi-person-circle" aria-hidden="true"></i> @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light btn-sm nav-action">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm nav-action" asp-controller="Account" asp-action="Register">Join CineBook</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="site-main" role="main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div>
                    <div class="brand-mark footer-brand">
                        <span class="brand-icon"><i class="bi bi-ticket-perforated-fill" aria-hidden="true"></i></span>
                        <span>CineBook</span>
                    </div>
                    <p class="footer-copy">Premium cinema booking, thoughtful seat selection, and in-seat snacks.</p>
                </div>
                <div class="footer-links">
                    <a asp-area="" asp-controller="Movies" asp-action="Index">Movies</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
            <div class="footer-bottom">&copy; 2026 CineBook. All rights reserved.</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
