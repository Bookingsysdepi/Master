@model CineBook.Dtos.Bookings.BookingConfirmationDto
@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="surface-card p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                <div class="d-flex gap-3">
                    <span class="confirmation-mark"><i class="bi bi-check2" aria-hidden="true"></i></span>
                    <div>
                        <div class="page-kicker">Booking confirmed</div>
                        <h1 class="h3 mb-1">@Model.MovieTitle</h1>
                        <p class="text-muted mb-0">Booking #@Model.Id</p>
                    </div>
                </div>
                <span class="status-badge is-good align-self-start">@Model.Status</span>
            </div>

            <dl class="row mb-4">
                <dt class="col-sm-4 text-muted">Hall</dt>
                <dd class="col-sm-8">@Model.HallName</dd>

                <dt class="col-sm-4 text-muted">Date</dt>
                <dd class="col-sm-8">@Model.StartTime.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-4 text-muted">Time</dt>
                <dd class="col-sm-8">@Model.StartTime.ToString("hh:mm tt")</dd>

                <dt class="col-sm-4 text-muted">Booked On</dt>
                <dd class="col-sm-8">@Model.BookingDate.ToString("dd MMM yyyy hh:mm tt")</dd>
            </dl>

            <h2 class="h5">Seats</h2>
            <div class="mb-4">
                @foreach (var seat in Model.Seats)
                {
                    <span class="badge text-bg-dark me-1 mb-1">@seat.RowLabel@seat.SeatNumber (@seat.SeatType)</span>
                }
            </div>

            <div class="d-flex justify-content-between border-top pt-3">
                <strong>Total Price</strong>
                <strong>@Model.TotalPrice.ToString("0.00") EGP</strong>
            </div>
        </div>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-primary">My Bookings</a>
            <a asp-controller="Movies" asp-action="Index" class="btn btn-outline-light">Back to Movies</a>
        </div>
    </div>
</div>
