@model CineBook.Dtos.Movies.MovieIndexDto
@{
    ViewData["Title"] = "Movies";
}

<div class="section-heading">
    <div class="page-kicker">Cinema catalog</div>
    <h1>Movies</h1>
    <p class="text-muted mb-0">Browse current movies and upcoming releases.</p>
</div>

<section class="mb-5" aria-labelledby="now-showing-title">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 id="now-showing-title" class="h3 mb-0">Now Showing</h2>
        <span class="status-badge is-good">@Model.NowShowingMovies.Count film(s)</span>
    </div>

    @if (Model.NowShowingMovies.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var movie in Model.NowShowingMovies)
            {
                <div class="col">
                    <partial name="_MovieCard" model="movie" />
                </div>
            }
        </div>
    }
    else
    {
        <partial name="_EmptyState" model="@("No movies are showing right now.")" />
    }
</section>

<section aria-labelledby="coming-soon-title">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 id="coming-soon-title" class="h3 mb-0">Coming Soon</h2>
        <span class="status-badge">@Model.ComingSoonMovies.Count film(s)</span>
    </div>

    @if (Model.ComingSoonMovies.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var movie in Model.ComingSoonMovies)
            {
                <div class="col">
                    <partial name="_MovieCard" model="movie" />
                </div>
            }
        </div>
    }
    else
    {
        <partial name="_EmptyState" model="@("No upcoming movies have been added yet.")" />
    }
</section>
