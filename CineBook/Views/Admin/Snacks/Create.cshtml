@model CineBook.Dtos.Snacks.CreateSnackDto

@{
    ViewData["Title"] = "Add Snack";
}

<div class="mb-4">
    <a href="/Admin/Snacks" class="back-link"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Canteen</a>
    <div class="page-kicker mt-3">Admin</div>
    <h1 class="h3 mt-3">Add Snack</h1>
</div>

<form method="post" action="/Admin/Snacks/Create" class="form-panel row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Category" class="form-label"></label>
        <select asp-for="Category" asp-items="Html.GetEnumSelectList<SnackCategory>()" class="form-select"></select>
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-8">
        <label asp-for="ImageUrl" class="form-label">Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
        <span asp-validation-for="ImageUrl" class="text-danger"></span>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="IsAvailable" class="form-check-input" />
            <label asp-for="IsAvailable" class="form-check-label">Available</label>
        </div>
    </div>

    <div class="col-12 admin-form-actions">
        <button type="submit" class="btn btn-primary">Save Snack</button>
        <a href="/Admin/Snacks" class="btn btn-outline-dark">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
