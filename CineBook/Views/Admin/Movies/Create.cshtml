@model CineBook.Dtos.Movies.CreateMovieDto

@{
    ViewData["Title"] = "Add Movie";
}

<div class="mb-4">
    <a href="/Admin/Movies" class="back-link"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Movies</a>
    <div class="page-kicker mt-3">Admin</div>
    <h1 class="h3 mt-3">Add Movie</h1>
</div>

<form method="post" action="/Admin/Movies/Create" class="form-panel row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-8">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Genre" class="form-label"></label>
        <select asp-for="Genre" asp-items="Html.GetEnumSelectList<Genre>()" class="form-select"></select>
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="DurationMinutes" class="form-label">Duration Minutes</label>
        <input asp-for="DurationMinutes" class="form-control" />
        <span asp-validation-for="DurationMinutes" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Language" class="form-label"></label>
        <input asp-for="Language" class="form-control" />
        <span asp-validation-for="Language" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<MovieStatus>()" class="form-select"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="col-md-8">
        <label asp-for="PosterUrl" class="form-label">Poster URL</label>
        <input asp-for="PosterUrl" class="form-control" />
        <span asp-validation-for="PosterUrl" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="ReleaseDate" class="form-label">Release Date</label>
        <input asp-for="ReleaseDate" type="date" class="form-control" />
        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
    </div>

    <div class="col-12 admin-form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/Admin/Movies" class="btn btn-outline-dark">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
