@model CineBook.Dtos.Employees.CreateEmployeeDto

@{
    ViewData["Title"] = "Add Employee";
}

<div class="mb-4">
    <a href="/Admin/Employees" class="back-link"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Employees</a>
    <div class="page-kicker mt-3">Admin</div>
    <h1 class="h3 mt-3">Add Employee</h1>
</div>

<form method="post" action="/Admin/Employees/Create" class="form-panel row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="FullName" class="form-label">Full Name</label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
        <input asp-for="PhoneNumber" class="form-control" placeholder="01xxxxxxxxx" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="NationalId" class="form-label">National ID</label>
        <input asp-for="NationalId" class="form-control" maxlength="14" inputmode="numeric" placeholder="14 digits" />
        <span asp-validation-for="NationalId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Salary" class="form-label"></label>
        <input asp-for="Salary" class="form-control" />
        <span asp-validation-for="Salary" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="HireDate" class="form-label">Hire Date</label>
        <input asp-for="HireDate" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
        <span asp-validation-for="HireDate" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="JobTitle" class="form-label">Job Title</label>
        <input asp-for="JobTitle" class="form-control" />
        <span asp-validation-for="JobTitle" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Department" class="form-label"></label>
        <select asp-for="Department" asp-items="Html.GetEnumSelectList<EmployeeDepartment>()" class="form-select"></select>
        <span asp-validation-for="Department" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="TemporaryPassword" class="form-label">Temporary Password</label>
        <input asp-for="TemporaryPassword" class="form-control" />
        <span asp-validation-for="TemporaryPassword" class="text-danger"></span>
    </div>

    <div class="col-12 admin-form-actions">
        <button type="submit" class="btn btn-primary">Save Employee</button>
        <a href="/Admin/Employees" class="btn btn-outline-dark">Cancel</a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
